# ---------------------------------------------------------------------------
# MCAG Loan Management System — environment variables
# Copy to .env for local development. NEVER commit the real .env file.
# ---------------------------------------------------------------------------

# Core
FLASK_ENV=development
FLASK_DEBUG=false
SECRET_KEY=replace-with-a-strong-random-secret
DATABASE_URL=postgresql://username:password@localhost:5432/mcag
PORT=5000
APP_NAME=MCAG Loan Management System
APP_BASE_URL=http://localhost:5000

# Sessions & cookies (set SESSION_COOKIE_SECURE=true in production/HTTPS)
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
SESSION_TIMEOUT_MINUTES=30

# Authentication policy
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30
PASSWORD_MIN_LENGTH=10

# Uploads
UPLOAD_FOLDER=uploads
MAX_UPLOAD_SIZE_MB=10

# Locale
LOG_LEVEL=INFO
DEFAULT_TIMEZONE=Africa/Accra
DEFAULT_CURRENCY=GHS

# Platform administrator bootstrap (used by: flask create-platform-admin)
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=

# Email (optional — password reset links are logged if unset)
MAIL_SERVER=
MAIL_PORT=
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_TLS=true
MAIL_DEFAULT_SENDER=

# SMS (optional)
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=

# Monitoring (optional)
SENTRY_DSN=

# Testing (optional; tests default to in-memory SQLite)
TEST_DATABASE_URL=
